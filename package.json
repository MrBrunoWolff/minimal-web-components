{
  "name": "minimal-web-components",
  "version": "0.1.0",
  "private": false,
  "description": "A minimal Web Components starter kit using Lit, Vite, and TypeScript",
  "keywords": [
    "boilerplate",
    "custom-elements",
    "lit",
    "scaffold",
    "starter",
    "template",
    "typescript",
    "vite",
    "web-components"
  ],
  "license": "MIT",
  "author": "Bruno Wolff",
  "repository": {
    "type": "git",
    "url": "https://github.com/MrBrunoWolff/minimal-web-components.git"
  },
  "bin": {
    "minimal-web-components": "bin/minimal-web-components.js"
  },
  "files": [
    "bin",
    "src",
    "__tests__",
    "index.html",
    "tsconfig.json",
    "vite.config.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "knip.config.ts",
    ".oxlintrc.json",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "check": "oxlint && oxfmt --check .",
    "knip": "knip",
    "clean": "rm -rf node_modules/.vite dist playwright-report test-results"
  },
  "dependencies": {
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/bun": "1.3.14",
    "@vitest/browser": "4.1.9",
    "@vitest/browser-playwright": "4.1.9",
    "knip": "6.17.1",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "terser": "5.48.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9",
    "vitest-browser-lit": "^1.0.1"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
