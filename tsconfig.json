{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["@types/bun"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "useDefineForClassFields": false,
    "experimentalDecorators": true,
    "useUnknownInCatchVariables": true
  },
  "include": ["src", "__tests__", "vite.config.ts", "vitest.config.ts", "playwright.config.ts", "knip.config.ts"]
}
